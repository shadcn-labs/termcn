{
  "name": "termcn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm registry:build && next build",
    "examples:build": "node ./scripts/build-examples.mts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "registry:build": "pnpm examples:build && node ./scripts/build-registry.mts",
    "registry:sync": "node ./scripts/audit-ink-registry.mts --write && oxfmt registry.json",
    "registry:validate": "node ./scripts/audit-ink-registry.mts",
    "docs:ink-v1": "node ./scripts/update-ink-v1-docs.mts",
    "test": "pnpm test:ink && pnpm test:registry",
    "test:ink": "JITI_JSX=1 JITI_ALIAS=\"{\\\"@\\\":\\\"$PWD\\\"}\" node --import jiti/register --test --test-concurrency=1 tests/terminal-text.test.mts tests/ink-interaction.test.mts tests/ink-accessibility.test.mts tests/ink-unicode.test.mts",
    "test:registry": "node --test tests/ink-registry-standalone.test.mts",
    "postinstall": "fumadocs-mdx",
    "check": "ultracite check && pnpm typecheck && pnpm registry:validate && pnpm test",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@gridland/utils": "^0.4.3",
    "@gridland/web": "^0.4.3",
    "@vercel/analytics": "^2.0.1",
    "@web-kits/audio": "^0.1.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "cli-spinners": "^3.4.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "front-matter": "^4.0.2",
    "fumadocs-core": "^16.7.10",
    "fumadocs-mdx": "^14.2.11",
    "glob": "13.0.6",
    "ink": "6.8.0",
    "ink-web": "0.2.0",
    "jiti": "^2.6.1",
    "jotai": "^2.19.0",
    "lru-cache": "^11.2.7",
    "lucide-react": "1.7.0",
    "marked": "17.0.5",
    "mnemonist": "0.40.3",
    "motion": "^12.38.0",
    "next": "16.2.2",
    "next-themes": "0.4.6",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "string-width": "8.2.0",
    "strip-ansi": "7.2.0",
    "tailwind-merge": "^3.5.0",
    "ts-morph": "^26.0.0",
    "vaul": "^1.1.2",
    "web-haptics": "^0.0.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "ink-testing-library": "^4.0.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "shadcn": "4.3.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "ultracite": "7.6.0"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2"
}
